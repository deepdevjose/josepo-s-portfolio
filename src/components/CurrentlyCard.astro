---
import Icon from "./Icon.astro";
import type { CurrentItem } from "../data/current";

interface Props {
  eyebrow: string;
  viewMore: string;
  items: CurrentItem[];
}

const { eyebrow, viewMore, items } = Astro.props;
---

<aside class="rounded-lg border border-black/10 bg-white p-6 shadow-sm">
  <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink">{eyebrow}</p>

  <div class="mt-7 grid gap-6">
    {items.map((item) => (
      <div class="flex gap-4">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-black/15 text-ink">
          <Icon name={item.icon} class="h-4 w-4" />
        </div>
        <div>
          <p class="text-sm font-semibold text-ink">{item.label}</p>
          <p class="mt-1 text-sm leading-5 text-muted">{item.value}</p>
        </div>
      </div>
    ))}
  </div>

  <a href="#about" class="group mt-8 inline-flex items-center gap-2 text-sm font-semibold text-ink">
    <span>{viewMore}</span>
    <Icon name="arrow-up-right" class="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
  </a>
</aside>
