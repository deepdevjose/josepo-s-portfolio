---
import SectionHeader from "./SectionHeader.astro";
import type { TimelineItem } from "../data/timeline";

interface Props {
  eyebrow: string;
  viewAll: string;
  items: TimelineItem[];
}

const { eyebrow, viewAll, items } = Astro.props;
---

<section id="about" class="min-w-0">
  <SectionHeader eyebrow={eyebrow} action={viewAll} href="#about" />

  <div class="relative mt-8 grid gap-7 sm:grid-cols-4">
    <div class="absolute left-0 right-0 top-[9px] hidden h-px bg-black/35 sm:block"></div>
    {items.map((item, index) => (
      <article class="relative">
        <span
          class:list={[
            "relative z-10 block h-4 w-4 rounded-full border bg-white",
            index === items.length - 1 ? "border-ink bg-ink" : "border-ink"
          ]}
        ></span>
        <time class="mt-4 block text-xs text-muted">{item.year}</time>
        <h3 class="mt-3 text-sm font-semibold text-ink">{item.title}</h3>
        <p class="mt-2 text-sm leading-5 text-muted">{item.description}</p>
      </article>
    ))}
  </div>
</section>
