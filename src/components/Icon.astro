---
import type { IconName } from "../data/site";

interface Props {
  name: IconName;
  class?: string;
  title?: string;
}

const { name, class: className = "h-4 w-4", title } = Astro.props;
const ariaAttrs = title ? { role: "img", "aria-label": title } : { "aria-hidden": "true" };
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  {...ariaAttrs}
>
  {name === "arrow-up-right" && (
    <>
      <path d="M7 17 17 7" />
      <path d="M9 7h8v8" />
    </>
  )}
  {name === "download" && (
    <>
      <path d="M12 3v12" />
      <path d="m7 10 5 5 5-5" />
      <path d="M5 21h14" />
    </>
  )}
  {name === "location" && (
    <>
      <path d="M12 21s6-5.2 6-11a6 6 0 0 0-12 0c0 5.8 6 11 6 11Z" />
      <circle cx="12" cy="10" r="2" />
    </>
  )}
  {name === "university" && (
    <>
      <path d="m4 10 8-5 8 5" />
      <path d="M6 10v8" />
      <path d="M10 10v8" />
      <path d="M14 10v8" />
      <path d="M18 10v8" />
      <path d="M4 18h16" />
    </>
  )}
  {name === "globe" && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18" />
      <path d="M12 3c2.4 2.5 3.6 5.5 3.6 9S14.4 18.5 12 21" />
      <path d="M12 3c-2.4 2.5-3.6 5.5-3.6 9s1.2 6.5 3.6 9" />
    </>
  )}
  {name === "flask" && (
    <>
      <path d="M10 3h4" />
      <path d="M11 3v6l-5.4 9.4A1.8 1.8 0 0 0 7.2 21h9.6a1.8 1.8 0 0 0 1.6-2.6L13 9V3" />
      <path d="M8 16h8" />
    </>
  )}
  {name === "academy" && (
    <>
      <path d="m3 8 9-5 9 5-9 5-9-5Z" />
      <path d="M7 10.5V15c2.7 2 7.3 2 10 0v-4.5" />
      <path d="M21 8v6" />
    </>
  )}
  {name === "community" && (
    <>
      <circle cx="8" cy="9" r="3" />
      <circle cx="17" cy="8" r="2.4" />
      <path d="M3 20c.7-3.2 2.4-5 5-5s4.3 1.8 5 5" />
      <path d="M14 15.5c2.7.2 4.6 1.7 5.5 4.5" />
    </>
  )}
  {name === "bridge" && (
    <>
      <path d="M4 18c3.2-6.5 12.8-6.5 16 0" />
      <path d="M6 18V8" />
      <path d="M18 18V8" />
      <path d="M6 8c3 2 9 2 12 0" />
    </>
  )}
  {name === "code" && (
    <>
      <path d="m8 9-4 3 4 3" />
      <path d="m16 9 4 3-4 3" />
      <path d="m13 6-2 12" />
    </>
  )}
  {name === "book" && (
    <>
      <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H21v16H6.5A2.5 2.5 0 0 0 4 21.5v-16Z" />
      <path d="M4 5.5A2.5 2.5 0 0 0 1.5 3H3v18.5" />
    </>
  )}
  {name === "github" && (
    <>
      <path d="M9 19c-4 1.2-4-2-5.5-2.5" />
      <path d="M15 22v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6A4.6 4.6 0 0 0 18.8 7 4.2 4.2 0 0 0 18.7 3s-1-.3-3.5 1.3a12.2 12.2 0 0 0-6.4 0C6.3 2.7 5.3 3 5.3 3a4.2 4.2 0 0 0-.1 4A4.6 4.6 0 0 0 4 10.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V22" />
    </>
  )}
  {name === "linkedin" && (
    <>
      <path d="M16 8a6 6 0 0 1 6 6v6h-4v-6a2 2 0 0 0-4 0v6h-4V9h4v2" />
      <path d="M2 9h4v11H2z" />
      <circle cx="4" cy="4" r="2" />
    </>
  )}
  {name === "email" && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m3 7 9 6 9-6" />
    </>
  )}
</svg>
