---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import type { HeroPill } from "../data/site";
import portrait from "../assets/nobgavatar.png";

interface Props {
  eyebrow: string;
  headline: string;
  subtitle: string;
  pills: HeroPill[];
  primaryCta: string;
  secondaryCta: string;
  cvHref?: string;
  portraitAlt: string;
  focusEyebrow: string;
  focusTitle: string;
  focusMeta: string;
  focusNote: string;
}

const {
  eyebrow,
  headline,
  subtitle,
  pills,
  primaryCta,
  secondaryCta,
  cvHref,
  portraitAlt,
  focusEyebrow,
  focusTitle,
  focusMeta,
  focusNote
} = Astro.props;


const headlineWords = headline.trim().split(/\s+/);
const splitIndex = headlineWords.length >= 4 ? 2 : Math.max(1, headlineWords.length - 1);
const headlineLead = headlineWords.length > 1 ? headlineWords.slice(0, splitIndex).join(" ") : headline;
const headlineTail = headlineWords.length > 1 ? headlineWords.slice(splitIndex).join(" ") : "";
const focusHref = "https://github.com/deepdevjose/Vision-Language-Runtime";
---

<section id="top" class="hero-gradient relative flex min-h-svh overflow-hidden border-b border-black/10 pt-20">
  <div class="hero-ambient absolute inset-0"></div>

  <div class="relative mx-auto flex w-full max-w-site px-5 lg:px-8">
    <div class="grid w-full items-center gap-8 pb-10 lg:min-h-[calc(100svh-5rem)] lg:grid-cols-[0.88fr_1.12fr] lg:pb-0">
      <div class="hero-copy relative z-10 flex flex-col items-start lg:pb-0">
        <p class="mono-label text-xs font-semibold uppercase text-ink">{eyebrow}</p>
        <h1 class="mt-5 max-w-2xl text-4xl font-bold leading-[0.96] text-ink sm:mt-7 sm:text-6xl lg:text-[4.25rem]" aria-label={headline}>
          <span class="block whitespace-nowrap">{headlineLead}</span>
          {headlineTail && <span class="block whitespace-nowrap">{headlineTail}</span>}
        </h1>
        <div class="mt-5 h-0.5 w-10 bg-accent sm:mt-7"></div>
        <p class="mt-4 max-w-md text-base font-medium leading-7 text-graphite sm:mt-5 sm:text-lg sm:leading-8">
          {subtitle}
        </p>

        <div class="mt-5 flex max-w-[520px] flex-wrap gap-2 sm:mt-8">
          {pills.map((pill) => (
            <div class="flex items-center gap-2 rounded-full border border-black/10 bg-white/55 px-3.5 py-1.5 text-xs font-semibold text-ink shadow-sm backdrop-blur sm:px-[1.125rem] sm:py-2 sm:text-sm">
              <Icon name={pill.icon} class="h-3.5 w-3.5 shrink-0 text-ink sm:h-4 sm:w-4" />
              <span class="leading-4">{pill.label}</span>
            </div>
          ))}
        </div>

        <div class="mt-6 flex w-full flex-col items-start gap-3 sm:mt-8 sm:flex-row sm:items-center">
          <a
            href="#projects"
            class="group inline-flex w-full justify-center items-center gap-2 rounded-lg bg-ink px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-black sm:w-auto"
          >
            <span>{primaryCta}</span>
            <Icon name="arrow-up-right" class="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
          <a
            href={cvHref ?? "/cv/jose-manuel-cortes-cv(english).pdf"}
            download
            class="group inline-flex w-full justify-center items-center gap-2 rounded-lg border border-black/10 bg-white px-5 py-3 text-sm font-semibold text-ink transition hover:bg-black/5 sm:w-auto"
          >
            <span>{secondaryCta}</span>
            <Icon name="download" class="h-4 w-4 transition group-hover:translate-y-0.5" />
          </a>
        </div>
      </div>

      <div class="hero-portrait-wrap hero-portrait-reveal pointer-events-none relative z-10 mt-6 flex flex-col items-center overflow-visible sm:mt-8 lg:mt-0 lg:pointer-events-auto lg:min-h-[calc(100svh-5rem)] lg:items-end lg:justify-end">
        <div class="relative flex h-56 w-full items-end justify-center overflow-hidden rounded-lg bg-white/35 ring-1 ring-black/5 sm:h-72 lg:h-auto lg:w-auto lg:overflow-visible lg:rounded-none lg:bg-transparent lg:ring-0">
          <Image
            src={portrait}
            alt={portraitAlt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            format="webp"
            quality={78}
            widths={[420, 640, 860, 1120, 1360]}
            sizes="(min-width: 1024px) 48vw, (min-width: 640px) 72vw, 86vw"
            class="hero-portrait relative z-10 h-[260px] w-auto max-w-none object-contain object-bottom opacity-100 sm:h-[360px] lg:h-[min(92svh,880px)] lg:translate-x-10"
          />
        </div>

        <aside class="hero-focus-card glass-dark surface-card-dark pointer-events-auto relative z-20 mt-6 w-full overflow-hidden rounded-lg p-4 text-white sm:mt-8 lg:absolute lg:bottom-14 lg:right-0 lg:mt-0 lg:w-[340px] lg:p-5">
          <div class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            <p class="mono-label text-[0.66rem] font-semibold uppercase text-white/80">{focusEyebrow}</p>
          </div>
          <h2 class="mt-3 text-base font-semibold sm:mt-4 sm:text-lg">{focusTitle}</h2>
          <p class="mt-2 text-sm text-white/72">{focusMeta}</p>
          <div class="mt-4 flex items-end justify-between gap-4 sm:mt-6">
            <p class="max-w-[26ch] text-xs leading-5 text-white/80 sm:text-sm">{focusNote}</p>
            <a
              href={focusHref}
              target="_blank"
              rel="noreferrer"
              class="group/repo inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-white/10 text-white transition hover:border-white/24 hover:bg-white/10"
              aria-label="Open Vision-Language Runtime repository"
            >
              <Icon name="arrow-up-right" class="h-4 w-4 transition group-hover/repo:translate-x-0.5 group-hover/repo:-translate-y-0.5" />
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
