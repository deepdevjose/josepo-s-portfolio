---
import Icon from "./Icon.astro";
import {
  languageOptions,
  localePaths,
  type Locale,
  type NavItem
} from "../data/site";

interface Props {
  brand: string;
  links: NavItem[];
  connect: string;
  languageLabel: string;
  locale: Locale;
}

const { brand, links, connect, languageLabel, locale } = Astro.props;
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-black/5 bg-paper/86 backdrop-blur-xl">
  <nav class="mx-auto max-w-site px-5 lg:px-8" aria-label="Primary navigation">
    <div class="flex h-16 items-center justify-between gap-4">
      <a href="#top" class="site-brand group flex items-center gap-2 font-semibold text-ink">
        <span>{brand}</span>
        <span class="h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_0_3px_rgba(167,74,255,0.12)] transition group-hover:scale-125"></span>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        {links.map((item) => (
          <a class="text-sm font-medium text-ink/78 transition hover:text-ink" href={item.href}>
            {item.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-2">
        <div class="hidden h-9 items-center gap-3 sm:flex" aria-label={languageLabel}>
          {languageOptions.map((option) => (
            <a
              href={localePaths[option.locale]}
              class:list={[
                "relative inline-flex h-8 items-center px-1 text-xs leading-none transition",
                option.locale === locale ? "font-bold text-ink after:absolute after:bottom-0 after:left-1/2 after:h-1 after:w-1 after:-translate-x-1/2 after:rounded-full after:bg-accent" : "font-semibold text-muted hover:text-ink"
              ]}
              aria-current={option.locale === locale ? "page" : undefined}
              title={option.name}
            >
              {option.label}
            </a>
          ))}
        </div>

        <a
          href="#contact"
          class="group hidden items-center gap-2 rounded-lg bg-ink px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-black md:inline-flex"
        >
          <span>{connect}</span>
          <Icon name="arrow-up-right" class="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
        </a>

        <button
          id="mobile-menu-button"
          aria-controls="mobile-menu"
          aria-expanded="false"
          class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-black/5 bg-white/90 p-0 text-ink md:hidden"
          aria-label="Open menu"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden fixed inset-0 z-[80] h-dvh w-screen flex-col overflow-y-auto bg-paper p-5 md:hidden" aria-hidden="true">
      <div class="flex items-center justify-between">
        <a href="#top" class="text-xl font-semibold">{brand}</a>
        <button id="mobile-menu-close" class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-black/5 bg-white p-0 text-ink" aria-label="Close menu">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <nav class="mt-8 flex flex-col gap-3" aria-label="Mobile primary">
        <a
          href="#contact"
          class="group inline-flex items-center justify-between rounded-lg bg-ink px-4 py-3 text-base font-semibold text-white shadow-sm"
        >
          <span>{connect}</span>
          <Icon name="arrow-up-right" class="h-4 w-4" />
        </a>

        {links.map((item) => (
          <a href={item.href} class="block rounded-lg px-4 py-3 text-lg font-semibold text-ink hover:bg-black/4">{item.label}</a>
        ))}

        <div class="mt-4 border-t border-black/6 pt-4">
          <p class="mb-2 text-sm text-muted">{languageLabel}</p>
          <div class="flex gap-2">
            {languageOptions.map((option) => (
              <a
                href={localePaths[option.locale]}
                class:list={[
                  "rounded-md px-3 py-2 text-sm font-semibold",
                  option.locale === locale ? "bg-ink text-white" : "text-muted hover:bg-black/4"
                ]}
                aria-current={option.locale === locale ? "page" : undefined}
              >
                {option.label}
              </a>
            ))}
          </div>
        </div>
      </nav>
    </div>

    <script>
      (function(){
        const btn = document.getElementById('mobile-menu-button');
        const close = document.getElementById('mobile-menu-close');
        const menu = document.getElementById('mobile-menu');
        if(!btn || !menu) return;
        function open(){
          menu.classList.remove('hidden');
          menu.setAttribute('aria-hidden','false');
          btn.setAttribute('aria-expanded','true');
          document.body.style.overflow='hidden';
        }
        function closeMenu(){
          menu.classList.add('hidden');
          menu.setAttribute('aria-hidden','true');
          btn.setAttribute('aria-expanded','false');
          document.body.style.overflow='';
        }
        btn.addEventListener('click', open);
        if(close) close.addEventListener('click', closeMenu);
        menu.addEventListener('click', (e)=>{ if(e.target===menu) closeMenu(); });
        menu.querySelectorAll('a').forEach((link)=>link.addEventListener('click', closeMenu));
      })();
    </script>
  </nav>
</header>
