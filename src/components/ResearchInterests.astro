---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  interests: string[];
}

const { eyebrow, title, description, interests } = Astro.props;
---

<section class="bg-white py-12 sm:py-16">
  <div class="mx-auto max-w-site px-5 lg:px-8">
    <div class="grid gap-8 rounded-lg border border-black/10 bg-white p-6 shadow-soft lg:grid-cols-[0.85fr_1.15fr] lg:p-8">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-ink">{eyebrow}</p>
        <h2 class="mt-5 max-w-md text-3xl font-semibold leading-tight text-ink sm:text-4xl">
          {title}
        </h2>
        <p class="mt-4 max-w-md text-base leading-7 text-muted">
          {description}
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {interests.map((interest) => (
          <div class="rounded-lg border border-black/10 bg-paper px-4 py-4 text-sm font-medium text-ink shadow-sm">
            {interest}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
