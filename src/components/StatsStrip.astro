---
import type { StatItem } from "../data/stats";

interface Props {
  stats: StatItem[];
  affiliations: string[];
}

const { stats, affiliations } = Astro.props;
---

<section id="stats" class="flex items-center bg-white py-8 sm:py-12">
  <div class="mx-auto max-w-site px-5 lg:px-8">
    <div class="grid overflow-hidden rounded-lg border border-black/10 bg-white shadow-soft lg:grid-cols-[3fr_1fr]">
      <div class="grid divide-y divide-black/10 sm:grid-cols-2 sm:divide-x sm:divide-y-0 lg:grid-cols-4">
        {stats.map((stat) => (
          <div class="flex flex-col items-center justify-center px-4 py-6 text-center min-h-[120px] sm:min-h-[140px]">
            <strong class="text-3xl sm:text-4xl font-semibold text-ink">{stat.value}</strong>
            <span class="mt-2 max-w-[160px] text-sm leading-5 text-muted">{stat.label}</span>
          </div>
        ))}
      </div>

      <div class="flex items-center justify-center border-t border-black/10 px-5 py-6 lg:border-l lg:border-t-0">
        <div class="grid gap-2 text-center">
          {affiliations.map((name) => (
            <span class="text-base sm:text-xl font-semibold uppercase leading-none text-ink">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
